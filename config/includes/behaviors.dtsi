/* Dead Keys */
#define DEAD_KEY_BASE 0x070100
#define DEAD_KEY(i) (DEAD_KEY_BASE + (i))
/* ------------- */

/* Home-Row Mods */
ZMK_HOLD_TAP(hml,
    flavor="balanced";
    tapping-term-ms=<280>;
    quick-tap-ms=<175>;
    require-prior-idle-ms=<130>;
    bindings=<&kp>,<&kp>;
    hold-trigger-key-positions = <KEYS_R THUMBS_L THUMBS_R>;
    hold-trigger-on-release;
)

ZMK_HOLD_TAP(hmr,
    flavor="balanced";
    tapping-term-ms=<280>;
    quick-tap-ms=<175>;
    require-prior-idle-ms=<130>;
    bindings=<&kp>,<&kp>;
    hold-trigger-key-positions = <KEYS_L THUMBS_L THUMBS_R>;
    hold-trigger-on-release;
)

#define HML(mod_key, alpha_key) &hml mod_key alpha_key // HRM Left Hand
#define HMR(mod_key, alpha_key) &hmr mod_key alpha_key // HRM Right Hand
/* ------------- */

/* OS Mode + BT Controls */
/* zmk-helpers v0.3 does not ship layer_toggle core, so define it locally. */
#ifndef ZMK_BEHAVIOR_CORE_layer_toggle
#define ZMK_BEHAVIOR_CORE_layer_toggle compatible = "zmk,behavior-toggle-layer"; #binding-cells = <1>
#endif

ZMK_BEHAVIOR(osw_on, layer_toggle, toggle-mode = "on";)
ZMK_BEHAVIOR(osw_off, layer_toggle, toggle-mode = "off";)

ZMK_MACRO(bt0_mac, bindings=<&macro_tap &bt BT_SEL 0 &osw_off OSW>;)
ZMK_MACRO(bt1_lnx, bindings=<&macro_tap &bt BT_SEL 1 &osw_on OSW>;)
ZMK_MACRO(os_tog, bindings=<&macro_tap &tog OSW>;)

ZMK_TAP_DANCE(
    bt_clr,
    tapping-term-ms=<250>;
    bindings=<&none>,<&bt BT_CLR>;
)
/* ----------- */

/* Auto Shift */
ZMK_HOLD_TAP(as,
    flavor="tap-preferred";
    tapping-term-ms=<180>;
    bindings=<&kp>,<&kp>;
)

#define AS_1(keycode) &as LS(keycode) keycode
#define AS_2(keycode1, keycode2) &as keycode2 keycode1
/* ------------- */

/* Haptic Feedback */
#define HAPTIC_OBG(node_name, device_ref, force_val) \
    node_name: node_name {                           \
        compatible = "zmk,output-behavior-generic";  \
        #binding-cells = <0>;                        \
        device = <device_ref>;                       \
        force = <force_val>;                         \
    };

#define OUTPUT_SOURCE_LAYER_STATE_CHANGE 1
#define HAPTIC_LAYER(node_name, bindings_list, layers_list)  \
    node_name: node_name {                                   \
        compatible = "zmk,output-behavior-listener";         \
        bindings = bindings_list;                            \
        layers = layers_list;                                \
        sources = <OUTPUT_SOURCE_LAYER_STATE_CHANGE>;        \
        all-state;                                           \
    };

#define OUTPUT_SOURCE_POSITION_STATE_CHANGE 2
#define HAPTIC_POSITION(node_name, pos_list, bindings_list, layers_list) \
    node_name: node_name {                                               \
        compatible = "zmk,output-behavior-listener";                     \
        bindings = bindings_list;                                        \
        position = pos_list;                                             \
        layers = layers_list;                                            \
        sources = <OUTPUT_SOURCE_POSITION_STATE_CHANGE>;                 \
    };

#define OUTPUT_SOURCE_KEYCODE_STATE_CHANGE 3
#define HAPTIC_KEYCODE(node_name, keycode, bindings_list, layers_list) \
    node_name: node_name {                                             \
        compatible = "zmk,output-behavior-listener";                   \
        bindings = bindings_list;                                      \
        position = keycode;                                            \
        layers = layers_list;                                          \
        sources = <OUTPUT_SOURCE_KEYCODE_STATE_CHANGE>;                \
    };

/ {
    HAPTIC_OBG(haptic_click_l, &haptic_l, 1)
    HAPTIC_OBG(haptic_click_r, &haptic_r, 1)
    HAPTIC_OBG(haptic_bump_l, &haptic_l, 7)
    HAPTIC_OBG(haptic_bump_r, &haptic_r, 7)
};
/* ----------- */

/* One-Shot Mods */
ZMK_STICKY_KEY(osm_sk,
    release-after-ms=<3000>;
    bindings=<&kp>;
    quick-release;
    lazy;
    ignore-modifiers;
)

ZMK_HOLD_TAP(osm,
    flavor="balanced";
    tapping-term-ms=<280>;
    bindings=<&kp>,<&osm_sk>;
    hold-while-undecided-linger;
)

#define OSM(keycode) &osm keycode keycode
/* ----------- */

/* Jump Cusor */
// To end of next word
ZMK_MACRO(j_nxt, bindings=<&macro_tap &kp LA(RIGHT)>;)
// To end of current word
ZMK_MACRO(j_end, bindings=<&macro_tap &kp LA(LEFT) &kp LA(RIGHT)>;)
// To beg of next word
ZMK_MACRO(j_prv, bindings=<&macro_tap &kp LA(LEFT)>;)
// To beg of current word
ZMK_MACRO(j_bgn, bindings=<&macro_tap &kp LA(RIGHT) &kp LA(LEFT)>;)

// Linux variants
ZMK_MACRO(j_nxt_l, bindings=<&macro_tap &kp LC(RIGHT)>;)
ZMK_MACRO(j_end_l, bindings=<&macro_tap &kp LC(LEFT) &kp LC(RIGHT)>;)
ZMK_MACRO(j_prv_l, bindings=<&macro_tap &kp LC(LEFT)>;)
ZMK_MACRO(j_bgn_l, bindings=<&macro_tap &kp LC(RIGHT) &kp LC(LEFT)>;)
/* ----------- */

/* Select Word */
// Jumps to the beginning of the current word and selects to the right of the cursor.
ZMK_MACRO(_s_nxt, bindings=<&macro_tap &kp LS(LA(RIGHT))>;)
ZMK_TRI_STATE(s_nxt, bindings=<&j_bgn>,<&_s_nxt>,<&none>;)

// Jump to the end of the current word and selects to the left of the cursor.
ZMK_MACRO(_s_prv, bindings=<&macro_tap &kp LS(LA(LEFT))>;)
ZMK_TRI_STATE(s_prv, bindings=<&j_end>,<&_s_prv>,<&none>;)

// Linux variants
ZMK_MACRO(_s_nxt_l, bindings=<&macro_tap &kp LS(LC(RIGHT))>;)
ZMK_TRI_STATE(s_nxt_l, bindings=<&j_bgn_l>,<&_s_nxt_l>,<&none>;)

ZMK_MACRO(_s_prv_l, bindings=<&macro_tap &kp LS(LC(LEFT))>;)
ZMK_TRI_STATE(s_prv_l, bindings=<&j_end_l>,<&_s_prv_l>,<&none>;)
/* ----------- */
